# ─────────────────────────────────────────────────────────────────────────────
# AI Chatbot Platform — Frontend Environment Variables
#
# Copy this file to `.env.local` and fill in real values:
#   cp .env.example .env.local
#
# All variables are NEXT_PUBLIC_* because they're consumed by the browser —
# none of these are secret, but they still shouldn't be committed since
# they point at a specific Supabase project/backend deployment.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the deployed FastAPI backend (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here
